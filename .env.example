# Copy this file to .env and fill in your values.
# NEVER commit .env — it contains secrets.
#
# Usage:
#   copy .env.example .env        (Windows)
#   cp .env.example .env          (Linux/macOS)

# ── Required ──────────────────────────────────────────────────────────────────

# OpenRouter API key — get one free at https://openrouter.ai
# Used to call the Llama 3.3 70B model for answer generation.
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── Optional (sensible defaults shown) ────────────────────────────────────────

# Shared API key for the HTTP API. Leave unset to disable authentication
# (fine for local/demo use). When set, every API call must send a matching
# `X-API-Key` header; the web UI prompts for it via the 🔑 button in the header.
# APP_API_KEY=choose-a-long-random-string

# LLM model to use via OpenRouter (OpenAI-compatible model ID)
MODEL_NAME=meta-llama/llama-3.3-70b-instruct

# Document chunking — larger chunks = more context per retrieval hit,
# but may dilute relevance. Overlap preserves sentences that cross chunk edges.
CHUNK_SIZE=800
CHUNK_OVERLAP=200

# Path where ChromaDB stores its persistent vector index.
# Use an absolute path or a path relative to where you run uvicorn.
# In Docker this is overridden to /app/chroma_db via docker-compose.yml.
CHROMA_DB_PATH=./chroma_db

# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
