{
  "description": "Labeled evaluation set for the HealthAI RAG pipeline. Each case maps a question to the source document(s) that should be retrieved, plus optional answer keywords. 'should_answer': false marks out-of-scope questions the assistant should refuse (abstain on).",
  "cases": [
    {
      "id": "appt-noshow-fee",
      "question": "What is the no-show fee?",
      "expected_sources": ["appointment_policy.txt"],
      "expected_keywords": ["25"],
      "should_answer": true
    },
    {
      "id": "appt-cancel-window",
      "question": "How far in advance do I need to cancel to avoid a fee?",
